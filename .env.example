NEXT_PUBLIC_SITE_URL=http://localhost:3000

# CMS login. Change both values before production deployment.
CMS_ADMIN_PASSWORD=replace-with-a-strong-password
SESSION_SECRET=replace-with-a-long-random-secret

# Production content storage for Vercel / Supabase.
# SUPABASE_SERVICE_ROLE_KEY is server-only. Never expose it in client code.
SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Legacy optional production content storage.
# When Supabase and Upstash are absent, the CMS writes to src/data/site.json locally.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional production media uploads for Vercel Blob.
BLOB_READ_WRITE_TOKEN=

# Additional trusted WeChat mini-program URL hostnames, comma-separated.
WECHAT_URL_ALLOWLIST=
